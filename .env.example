PORT=4000
MONGODB_URI=mongodb://localhost:27017/url_shortner
JWT_SECRET=your_jwt_secret_here
BASE_URL=http://localhost:4000
# Optional. When set, BASE_URL origin + localhost/127.0.0.1 on PORT are merged in dev so Swagger at /api/docs works.
# In dev we also allow common frontend dev origins (5173 for Vite, 3000 for CRA).
CORS_ORIGIN=http://localhost:5173

